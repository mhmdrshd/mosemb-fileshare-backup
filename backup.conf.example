# backup.conf.example - template for backup_docs.sh configuration.
#
# Copy to backup.conf (next to the script) and edit the values.
# The real backup.conf is gitignored: it holds machine-specific paths
# and share names that don't belong in the repo.
#
# This file is sourced by bash, so it must be valid bash syntax.
# Keep it to plain variable assignments only - no commands.
#
# shellcheck shell=bash
# shellcheck disable=SC2034  # variables are consumed by backup_docs.sh

# SOURCE_DIRS - bash array of directories to back up (CIFS mount points).
# An array, not a space-separated string: a path like "/mnt/docs/Q3 Reports"
# would split into two bogus paths if we looped over a plain string.
SOURCE_DIRS=(
    "/mnt/smb/documents"
    "/mnt/smb/scans"
)

# SMB_SERVER - file server FQDN, used by the preflight connectivity checks.
# FQDN, not IP: mapping by IP forces NTLM instead of Kerberos and silently
# breaks the day the server's address changes.
SMB_SERVER="fileserver.example.local"

# BACKUP_MOUNT - mountpoint of the external backup drive. Verified with
# mountpoint(1) before every run: if the drive is absent, this is a plain
# directory and a backup would fill the root filesystem instead.
BACKUP_MOUNT="/mnt/backup"

# BACKUP_DEST - directory on the external drive where copies land.
# Must be BACKUP_MOUNT or a path under it (validated at startup).
BACKUP_DEST="/mnt/backup/docs"

# MIN_FREE_GB - refuse to run with less than this many GB free at
# BACKUP_DEST. A floor, not a prediction: incremental runs need far less
# than a full copy. 0 disables the check.
MIN_FREE_GB=5

# LOG_FILE - where run logs are appended.
LOG_FILE="${HOME}/backup_docs.log"
